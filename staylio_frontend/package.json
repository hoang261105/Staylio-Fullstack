{
  "name": "staylio_frontend",
  "private": true,
  "workspaces": [
    "admin",
    "user"
  ],
  "scripts": {
    "dev:admin": "npm run dev --workspace=admin",
    "dev:user": "npm run dev --workspace=user",
    "dev": "concurrently \"npm run dev:admin\" \"npm run dev:user\"",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "concurrently": "^8.0.0",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "react-router-dom": "^6.30.3"
  }
}
