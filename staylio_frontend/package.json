{
  "name": "staylio_frontend",
  "private": true,
  "workspaces": [
    "admin",
    "user",
    "manager"
  ],
  "scripts": {
    "dev:admin": "npm run dev --workspace=admin",
    "dev:user": "npm run dev --workspace=user",
    "dev:manager": "npm run dev --workspace=manager",
    "dev": "concurrently \"npm run dev:admin\" \"npm run dev:user\" \"npm run dev:manager\"",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/leaflet": "^1.9.21",
    "concurrently": "^8.0.0",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@react-oauth/google": "^0.13.5",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.100.9",
    "@types/react-datepicker": "^6.2.0",
    "axios": "^1.14.0",
    "dayjs": "^1.11.20",
    "i18next": "^26.3.1",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "react-datepicker": "^9.1.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.3",
    "react-select": "^5.10.2"
  }
}
